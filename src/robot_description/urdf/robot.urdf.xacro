<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="demo_robot">

  <!-- Robot dimensions -->
  <xacro:property name="base_length"     value="0.30"/>
  <xacro:property name="base_width"      value="0.20"/>
  <xacro:property name="base_height"     value="0.10"/>
  <xacro:property name="wheel_radius"    value="0.05"/>
  <xacro:property name="wheel_width"     value="0.03"/>
  <!-- Distance between the two driven wheels - track width -->
  <xacro:property name="wheel_separation" value="0.30"/>
  <!-- Caster sphere radius — equal to wheel_radius so joint z needs no offset -->
  <xacro:property name="caster_radius"   value="0.05"/>

  <!-- base_link -->
  <!-- The root link of the robot defining all other children links, 
       visualization, collision and inertia properties
  -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <!--
        Inertia of a solid box (m=2, l=0.30, w=0.20, h=0.10):
          Ixx = m/12*(w²+h²) = 2/12*(0.04+0.01) = 0.00833
          Iyy = m/12*(l²+h²) = 2/12*(0.09+0.01) = 0.01667
          Izz = m/12*(l²+w²) = 2/12*(0.09+0.04) = 0.02167
      -->
      <inertia
        ixx="0.00833"
        iyy="0.01667"
        izz="0.02167"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- Wheel macro -->
  <xacro:macro name="wheel" params="prefix y_offset">

    <link name="${prefix}_wheel">
      <visual>
        <!-- Cylinder is defined along Z by default; rotating ±90° maps Z→Y -->
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="dark_grey">
          <color rgba="0.15 0.15 0.15 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.3"/>
        <!--
          The wheel's spin axis is Y (joint axis="0 1 0"), so Iyy is the
          axial moment and Ixx=Izz are the transverse moments.
          Cylinder (m=0.3, r=0.05, l=0.03) with axis along Y:
            Iyy = m/2 * r²          = 0.3/2  * 0.0025 = 0.000375
            Ixx = Izz = m/12*(3r²+l²) = 0.3/12 * 0.0084 = 0.000210
        -->
        <inertia
          ixx="0.000210"
          iyy="0.000375"
          izz="0.000210"
          ixy="0.0" ixz="0.0" iyz="0.0"/>
      </inertial>
    </link>

    <!--
      continuous joint = can rotate freely with no limits (unlike revolute).
      The wheel spins around the Y axis of base_link.
      The wheel centre sits at half the base height below, at the Y offset.
    -->
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${prefix}_wheel"/>
      <origin xyz="0.0 ${y_offset} ${-base_height/2}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

  </xacro:macro>

  <!-- Instantiate left and right driven wheels -->
  <xacro:wheel prefix="left"  y_offset=" ${wheel_separation/2}"/>
  <xacro:wheel prefix="right" y_offset="-${wheel_separation/2}"/>

  <!--s Caster wheel -->
  <!--
    A passive (non-driven) support at the front without rotation in URDF
    Gazebo simulates it as a frictionless sphere so it pivots freely.
  -->
  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="light_grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <!-- Inertia of a solid sphere (r=0.05): I = 2/5 * m * r² = 0.00005 -->
      <inertia
        ixx="0.00005"
        iyy="0.00005"
        izz="0.00005"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_wheel"/>
    <!--
      caster_radius = wheel_radius, so the caster bottom is at the same height
      as the driven wheel bottoms.  Joint z = -base_height/2 places the caster
      centre at the same level as the wheel axles (z=0 in base_link frame),
      which means the caster bottom touches z = caster_centre - caster_radius =
      -wheel_radius = the same ground contact as the driven wheels.
    -->
    <origin xyz="${base_length/2 - caster_radius} 0 ${-base_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- Gazebo extensions -->
  <!-- Make the caster frictionless so it pivots without fighting the drive wheels -->
  <gazebo reference="caster_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!--
    DiffDrive plugin: Gazebo reads cmd_vel (Gazebo transport topic) and
    drives left/right wheel joints; it publishes odometry to odom_topic.
    The ros_gz_bridge in the launch file maps these Gazebo topics ↔ ROS2.
  -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>20</odom_publish_frequency>
      <!-- Limit how fast wheel velocity can change — prevents impulse torques
           that destabilise the DART constraint solver on step commands. -->
      <max_linear_acceleration>2.0</max_linear_acceleration>
      <min_linear_acceleration>-2.0</min_linear_acceleration>
      <max_angular_acceleration>4.0</max_angular_acceleration>
      <min_angular_acceleration>-4.0</min_angular_acceleration>
    </plugin>
  </gazebo>

  <!--
    JointStatePub plugin: publishes wheel joint positions so robot_state_publisher
    can compute the wheel TF and RViz can animate the wheels spinning.
  -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
    </plugin>
  </gazebo>

</robot>
